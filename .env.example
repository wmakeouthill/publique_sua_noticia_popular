# ============================================================
# Portal de Notícias Populares — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# ============================================================

# === Banco de Dados ===
PG_DATABASE=noticiapopular
PG_USER=noticiapopular
PG_PASSWORD=TROCAR_SENHA_SEGURA
# Porta do host para expor o Postgres do Docker (container continua em 5432)
PG_HOST_PORT=5433

# === JWT ===
# Chave com mínimo de 32 caracteres (256 bits)
JWT_SECRET=TROCAR_POR_CHAVE_256_BITS_MINIMO_32_CHARS_AQUI
JWT_EXPIRATION=3600000

# === Backend ===
# Porta do host para expor a API do Docker (container continua em 8080)
BACKEND_HOST_PORT=8082

# === Google OAuth2 ===
# Obtenha em: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Lista separada por vírgula de e-mails Google com papel ADMIN
ADMIN_GOOGLE_EMAILS=

# === Gemini API ===
# Obtenha em: https://aistudio.google.com/
GEMINI_API_KEY=

# === Frontend ===
NG_APP_API_URL=http://localhost:8082/api/v1
NG_APP_GOOGLE_CLIENT_ID=